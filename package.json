{
  "name": "@hadidyapp/audio-node",
  "version": "0.1.0",
  "description": "Node.js SDK extensions for Hadidy Audio — file streaming, disk uploads, webhook middleware",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@hadidyapp/audio-sdk": "^0.1.0"
  },
  "devDependencies": {
    "@hadidyapp/audio-sdk": "^0.1.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": ["audio", "transcoding", "node", "sdk", "hadidy"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hadidyapp/audio-node.git"
  }
}
